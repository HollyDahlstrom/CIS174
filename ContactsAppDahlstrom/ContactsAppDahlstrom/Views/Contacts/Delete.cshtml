@* 
Delete.cshtml
EF Core Web App Lab - ContactsAppDahlstrom

Displays details of a contact for deletion confirmation.
User must confirm to delete the contact from the database.
Includes Cancel button to return to the Contact List page.

Author: Holly Dahlstrom
Date: Jan 23, 2026
Course: CIS174
*@

@model ContactsAppDahlstrom.Models.Contact

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Contact</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" />
</head>
<body class="p-4">
    <div class="container">
        <h2 class="mb-3">Delete Contact</h2>

        <p>Are you sure you want to delete the following contact?</p>

        <div class="card p-3 mb-3">
            <p><strong>Name:</strong> @Model.Name</p>
            <p><strong>Phone:</strong> @Model.PhoneNumber</p>
            <p><strong>Address:</strong> @Model.Address</p>
            <p><strong>Note:</strong> @Model.Note</p>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>

    <!-- Optional: jQuery validation scripts if needed -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.6/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate-unobtrusive/3.2.13/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
