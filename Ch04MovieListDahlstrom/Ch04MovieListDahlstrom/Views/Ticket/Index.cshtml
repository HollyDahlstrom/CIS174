@model IEnumerable<Ch04MovieListDahlstrom.Models.Ticket>
@{
    ViewData["Title"] = "Ticketing System";
}

<h1>Ticketing System</h1>

<div class="row">
    <!-- Filter Panel -->
    <div class="col-md-2">
        <form asp-action="Index" method="get">
            <div class="mb-3">
                <label class="form-label">Status:</label>
                <select name="statusFilter" class="form-select">
                    <option value="all" selected="@(ViewBag.StatusFilter == "all" ? "selected" : null)">All</option>
                    @foreach (var status in ViewBag.Statuses as List<Ch04MovieListDahlstrom.Models.Status>)
                    {
                        <option value="@status.Name" selected="@(ViewBag.StatusFilter == status.Name ? "selected" : null)">
                            @status.Name
                        </option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-action="Index" class="btn btn-secondary">Clear</a>
            </div>
        </form>
    </div>

    <!-- Ticket Table -->
    <div class="col-md-10">
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Points</th>
                    <th>Status</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model)
                {
                    <tr>
                        <td>@ticket.Name</td>
                        <td>@ticket.Description</td>
                        <td>@ticket.PointValue</td>
                        <td>@ticket.Status.Name</td>
                        <td>@ticket.CreatedDate.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="d-flex gap-2 mt-3">
            <a asp-action="Add" class="btn btn-primary">Add New Ticket</a>
            <form asp-action="DeleteCompleted" method="post">
                <button type="submit" class="btn btn-danger">Delete Completed Tasks</button>
            </form>
        </div>
    </div>
</div>