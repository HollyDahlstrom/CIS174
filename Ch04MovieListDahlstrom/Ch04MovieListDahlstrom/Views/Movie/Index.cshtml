@model List<Movie>
@{
    ViewBag.Title = "My Movies";
}
<h2>@ViewData["ViewDataProperty"]</h2>
<h1 class="display-4">Welcome @ViewBag.Name</h1>
@if (ViewBag.Name == "Student")
{
    <p>Hello, Student</p>
}

<h2>Movie List</h2>
<a asp-controller="Movie" asp-action="Add">Add New Movie</a>
<table class="table table-hover">
    <thead>
        <tr><th>Name</th><th>Year</th><th>Rating</th><th>Genre</th></tr>
    </thead>
    <tbody>
        @foreach (var movie in Model) {
        <tr>
            <td>@movie.Name</td>
            <td>@movie.Year</td>            
            <td>@movie.Rating</td>
            <td>@movie.Genre.Name</td>
            <td>
                <a asp-controller="Movie" asp-action="Edit"
                   asp-route-id="@movie.MovieId"
                   asp-route-slug="@movie.Slug"
                   class="btn btn-primary">Edit</a>
                <a asp-controller="Movie" asp-action="Delete"
                   asp-route-id="@movie.MovieId"
                   asp-route-slug="@movie.Slug"
                   class="btn btn-primary">Delete</a>
            </td>
        </tr>
        }
    </tbody>
</table>